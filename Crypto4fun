<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --gold:#F7B731;--gold-dark:#e0a000;--dark:#0A0E1A;--dark2:#111827;--dark3:#1a2235;
  --card:#161d2e;--border:rgba(247,183,49,0.18);--text:#e8eaf0;--muted:#8892a4;
  --green:#00d68f;--red:#ff4757;--radius:14px
}
body{font-family:'Inter',sans-serif;background:var(--dark);color:var(--text);overflow-x:hidden}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:100;backdrop-filter:blur(16px);background:rgba(10,14,26,0.85);border-bottom:1px solid var(--border);padding:0 6%}
.nav-inner{max-width:1200px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;height:68px}
.logo{font-size:1.4rem;font-weight:800;color:#fff;letter-spacing:-0.5px}
.logo span{color:var(--gold)}
.nav-links{display:flex;gap:32px;list-style:none}
.nav-links a{text-decoration:none;color:var(--muted);font-size:0.9rem;font-weight:500;transition:color .2s}
.nav-links a:hover{color:#fff}
.nav-cta{background:var(--gold);color:#0A0E1A;border:none;padding:10px 22px;border-radius:8px;font-weight:700;font-size:0.88rem;cursor:pointer;transition:background .2s}
.nav-cta:hover{background:var(--gold-dark)}

/* HERO */
.hero{min-height:100vh;display:flex;align-items:center;padding:110px 6% 80px;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;top:-200px;right:-100px;width:700px;height:700px;background:radial-gradient(circle,rgba(247,183,49,0.08) 0%,transparent 65%);pointer-events:none}
.hero::after{content:'';position:absolute;bottom:-150px;left:-150px;width:500px;height:500px;background:radial-gradient(circle,rgba(88,130,255,0.07) 0%,transparent 65%);pointer-events:none}
.hero-inner{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center;width:100%}
.badge{display:inline-flex;align-items:center;gap:8px;background:rgba(247,183,49,0.1);border:1px solid var(--border);padding:6px 14px;border-radius:50px;font-size:0.8rem;color:var(--gold);font-weight:600;margin-bottom:24px}
.badge-dot{width:7px;height:7px;background:var(--gold);border-radius:50%;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(1.3)}}
h1{font-size:3.4rem;font-weight:800;line-height:1.12;letter-spacing:-1px;margin-bottom:20px}
h1 .highlight{color:var(--gold)}
.hero-sub{font-size:1.08rem;color:var(--muted);line-height:1.7;margin-bottom:36px;max-width:480px}
.hero-btns{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:48px}
.btn-primary{background:var(--gold);color:#0A0E1A;padding:14px 28px;border-radius:10px;border:none;font-weight:700;font-size:0.95rem;cursor:pointer;transition:all .2s}
.btn-primary:hover{background:var(--gold-dark);transform:translateY(-1px)}
.btn-secondary{background:transparent;color:#fff;padding:14px 28px;border-radius:10px;border:1px solid rgba(255,255,255,0.2);font-weight:600;font-size:0.95rem;cursor:pointer;transition:all .2s}
.btn-secondary:hover{border-color:rgba(255,255,255,0.5);background:rgba(255,255,255,0.04)}
.stats{display:flex;gap:36px}
.stat-item{}
.stat-num{font-size:1.7rem;font-weight:800;color:#fff}
.stat-label{font-size:0.78rem;color:var(--muted);margin-top:2px}

/* HERO CARD */
.hero-visual{position:relative}
.dashboard-card{background:var(--card);border:1px solid var(--border);border-radius:20px;padding:24px;position:relative;overflow:hidden}
.dashboard-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--gold),transparent)}
.card-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px}
.card-title{font-size:0.82rem;color:var(--muted);font-weight:500}
.live-badge{background:rgba(0,214,143,0.12);color:var(--green);font-size:0.72rem;font-weight:700;padding:3px 10px;border-radius:50px;display:flex;align-items:center;gap:5px}
.live-dot{width:5px;height:5px;background:var(--green);border-radius:50%;animation:pulse 1.5s infinite}
.price-big{font-size:2.2rem;font-weight:800;color:#fff;margin-bottom:4px}
.price-change{font-size:0.85rem;color:var(--green);font-weight:600;display:flex;align-items:center;gap:4px;margin-bottom:20px}
/* mini chart */
.mini-chart{height:72px;margin-bottom:20px;position:relative}
.mini-chart svg{width:100%;height:100%}
.chart-line{fill:none;stroke:var(--gold);stroke-width:2.2;stroke-linecap:round;stroke-linejoin:round}
.chart-area{fill:url(#areaGrad);opacity:0.35}
.coins-row{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-bottom:16px}
.coin-item{background:rgba(255,255,255,0.04);border-radius:10px;padding:10px 12px;border:1px solid rgba(255,255,255,0.06)}
.coin-name{font-size:0.72rem;color:var(--muted);margin-bottom:4px}
.coin-price{font-size:0.88rem;font-weight:700;color:#fff;margin-bottom:2px}
.coin-pct{font-size:0.72rem;font-weight:600}
.up{color:var(--green)}.down{color:var(--red)}
/* floating tags */
.float-tag{position:absolute;background:var(--card);border:1px solid var(--border);border-radius:12px;padding:10px 14px;font-size:0.78rem;font-weight:600;display:flex;align-items:center;gap:7px;backdrop-filter:blur(8px)}
.float-1{top:-18px;right:30px;color:var(--green)}
.float-2{bottom:30px;left:-30px;color:#a78bfa}

/* MARQUEE */
.ticker{background:rgba(247,183,49,0.06);border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:12px 0;overflow:hidden}
.ticker-inner{display:flex;animation:marquee 22s linear infinite;white-space:nowrap;gap:0}
@keyframes marquee{from{transform:translateX(0)}to{transform:translateX(-50%)}}
.tick-item{display:flex;align-items:center;gap:8px;padding:0 28px;font-size:0.82rem;font-weight:600;color:var(--text)}
.tick-sep{color:var(--border);font-size:1.2rem}

/* COURSES */
.section{padding:90px 6%}
.section-inner{max-width:1200px;margin:0 auto}
.section-label{font-size:0.8rem;font-weight:700;color:var(--gold);letter-spacing:2px;text-transform:uppercase;margin-bottom:12px}
.section-title{font-size:2.4rem;font-weight:800;letter-spacing:-0.5px;margin-bottom:14px}
.section-sub{font-size:1rem;color:var(--muted);max-width:540px;line-height:1.7}
.courses-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;margin-top:48px}
.course-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;transition:transform .25s,border-color .25s;cursor:pointer}
.course-card:hover{transform:translateY(-5px);border-color:rgba(247,183,49,0.45)}
.course-img{height:140px;display:flex;align-items:center;justify-content:center;font-size:3rem;position:relative}
.bg-blue{background:linear-gradient(135deg,#0d1f3c 0%,#1a3a6b 100%)}
.bg-purple{background:linear-gradient(135deg,#1a0a2e 0%,#3d1c6b 100%)}
.bg-green{background:linear-gradient(135deg,#041f13 0%,#084d2e 100%)}
.course-level{position:absolute;top:10px;right:10px;font-size:0.7rem;font-weight:700;padding:4px 10px;border-radius:50px}
.lv-beg{background:rgba(0,214,143,0.15);color:var(--green)}
.lv-int{background:rgba(247,183,49,0.15);color:var(--gold)}
.lv-adv{background:rgba(255,71,87,0.15);color:var(--red)}
.course-body{padding:18px}
.course-name{font-size:1rem;font-weight:700;margin-bottom:6px}
.course-desc{font-size:0.82rem;color:var(--muted);line-height:1.6;margin-bottom:14px}
.course-meta{display:flex;justify-content:space-between;align-items:center}
.course-price{font-size:1.1rem;font-weight:800;color:var(--gold)}
.course-lessons{font-size:0.75rem;color:var(--muted)}
.enroll-btn{width:100%;margin-top:14px;background:rgba(247,183,49,0.1);color:var(--gold);border:1px solid var(--border);border-radius:8px;padding:10px;font-weight:700;font-size:0.85rem;cursor:pointer;transition:all .2s}
.enroll-btn:hover{background:var(--gold);color:#0A0E1A}

/* FEATURES */
.features-bg{background:var(--dark2)}
.features-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;margin-top:48px}
.feat-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:26px;transition:border-color .2s}
.feat-card:hover{border-color:rgba(247,183,49,0.4)}
.feat-icon{width:46px;height:46px;border-radius:12px;background:rgba(247,183,49,0.1);display:flex;align-items:center;justify-content:center;font-size:1.4rem;margin-bottom:16px}
.feat-title{font-size:1rem;font-weight:700;margin-bottom:8px}
.feat-text{font-size:0.84rem;color:var(--muted);line-height:1.65}

/* TESTIMONIALS */
.test-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;margin-top:48px}
.test-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:24px}
.stars{color:var(--gold);font-size:1rem;margin-bottom:12px;letter-spacing:2px}
.test-text{font-size:0.88rem;color:var(--muted);line-height:1.7;margin-bottom:16px;font-style:italic}
.test-author{display:flex;align-items:center;gap:10px}
.avatar{width:38px;height:38px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:0.8rem}
.av1{background:rgba(247,183,49,0.15);color:var(--gold)}
.av2{background:rgba(88,130,255,0.15);color:#5882ff}
.av3{background:rgba(0,214,143,0.15);color:var(--green)}
.author-name{font-size:0.88rem;font-weight:700}
.author-role{font-size:0.75rem;color:var(--muted)}

/* CTA BANNER */
.cta-banner{background:var(--dark3);border:1px solid var(--border);border-radius:20px;padding:60px 50px;text-align:center;margin:0 6% 80px;position:relative;overflow:hidden}
.cta-banner::before{content:'';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:500px;height:300px;background:radial-gradient(ellipse,rgba(247,183,49,0.07) 0%,transparent 70%);pointer-events:none}
.cta-banner h2{font-size:2.5rem;font-weight:800;margin-bottom:14px;letter-spacing:-0.5px}
.cta-banner p{font-size:1rem;color:var(--muted);margin-bottom:32px}
.cta-input-row{display:flex;gap:12px;justify-content:center;flex-wrap:wrap}
.email-input{background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.12);border-radius:10px;padding:13px 20px;color:#fff;font-size:0.92rem;width:300px;outline:none;font-family:'Inter',sans-serif}
.email-input::placeholder{color:var(--muted)}
.email-input:focus{border-color:var(--gold)}

/* FOOTER */
footer{border-top:1px solid var(--border);padding:48px 6% 32px;max-width:100%}
.footer-inner{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:40px;margin-bottom:40px}
.footer-brand p{font-size:0.85rem;color:var(--muted);line-height:1.7;margin-top:10px;max-width:220px}
.footer-col h4{font-size:0.82rem;font-weight:700;color:var(--gold);text-transform:uppercase;letter-spacing:1.5px;margin-bottom:16px}
.footer-col a{display:block;font-size:0.85rem;color:var(--muted);text-decoration:none;margin-bottom:10px;transition:color .2s}
.footer-col a:hover{color:#fff}
.footer-bottom{border-top:1px solid var(--border);padding-top:24px;display:flex;justify-content:space-between;align-items:center;font-size:0.8rem;color:var(--muted)}

@media(max-width:900px){
  .hero-inner{grid-template-columns:1fr}
  .hero-visual{display:none}
  h1{font-size:2.4rem}
  .courses-grid,.features-grid,.test-grid{grid-template-columns:1fr 1fr}
  .footer-inner{grid-template-columns:1fr 1fr}
}
@media(max-width:600px){
  .courses-grid,.features-grid,.test-grid{grid-template-columns:1fr}
  .nav-links{display:none}
  h1{font-size:2rem}
  .stats{gap:20px}
  .cta-banner{padding:40px 24px}
  .cta-banner h2{font-size:1.8rem}
}
</style>
</head>
